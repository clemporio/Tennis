# Tennis dry-run / executor configuration
# Copy to .env and fill in real values for live mode.

# Mode toggle — "dry_run" records paper trades only; "live" signs and submits real fill orders
TENNIS_MODE=dry_run

# Per-pick stake in USD (matches Phase 1 PAPER_STAKE for direct comparability)
TENNIS_BASE_STAKE_USD=25.0

# Risk caps (live mode only)
MAX_DAILY_STAKE_USD=100.0
MAX_MATCH_LIABILITY_USD=50.0

# Kill switch — touch this file to halt live order placement immediately
KILL_SWITCH_PATH=/opt/tennis-dry-run/.tmp/KILL

# Where the audit journal of submit/response/settled events is written
ORDERS_JOURNAL_PATH=/opt/tennis-dry-run/.tmp/orders.jsonl

# SX Bet wallet credentials (live mode only — leave blank in dry_run)
SXBET_WALLET_ADDRESS=
SXBET_PRIVATE_KEY=

# SX Bet API base URL (override only for testing/staging)
SXBET_API_BASE=https://api.prod.sx.bet
